{
  "name": "open-knowledge-hub",
  "version": "0.1.0",
  "description": "An MCP server that manages a personal catalog of OKF knowledge packs, each published to its own git repo.",
  "license": "MIT",
  "type": "module",
  "bin": {
    "open-knowledge-hub": "dist/index.js"
  },
  "files": [
    "dist",
    "resources"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepare": "npm run build"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "yaml": "^2.6.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^4.1.9"
  }
}
